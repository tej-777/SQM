# Production Environment Variables for Vercel Deployment
# Copy these to your Vercel Environment Variables

# API Configuration - MOST IMPORTANT
VITE_API_BASE_URL=https://sqm-8vrc.onrender.com

# Application Configuration
VITE_APP_TITLE=TREFIX - Smart Queue System
VITE_APP_VERSION=1.0.0

# Note: VITE_ prefixed variables are exposed to frontend
# DATABASE_URL should only be set in Render backend, not frontend
